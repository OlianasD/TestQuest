<idea-plugin>
    <id>com.example.demo</id>
    <name>Demo</name>
    <vendor email="your-email@example.com" url="https://www.example.com">Your Name</vendor>
    <description><![CDATA[
        A demo plugin to test if everything works fine.
    ]]></description>
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Definisci qui le tue estensioni -->
    </extensions>

    <actions>
        <group id="Gamify.EvaluateTestsAction" text="Gamify">
            <add-to-group group-id="MainMenu" anchor="last" />
            <action class="com.example.demo.TestQuestAction" id="Demo.Action.TestQuestAction" text="Test Quest"/>
        </group>
    </actions>

    <projectListeners>
        <listener class="listener.TestListener"
                  topic="com.intellij.execution.testframework.sm.runner.SMTRunnerEventsListener"/>
    </projectListeners>


</idea-plugin>
